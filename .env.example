# App
APP_NAME=StrongX
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://strongx:strongx_pass@postgres:5432/strongx_db

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET_KEY=change-me-to-another-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# TelcoSMS (SMS proxy → telcosms.co.ao)
TELCOSMS_URL=https://telcosms.co.ao/send_message
TELCOSMS_API_KEY=your-telcosms-api-key

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# AppyPay OAuth2
APPYPAY_TOKEN_URL=https://login.microsoftonline.com/your-tenant/oauth2/token
APPYPAY_CLIENT_ID=your-appypay-client-id
APPYPAY_CLIENT_SECRET=your-appypay-client-secret
APPYPAY_RESOURCE=your-appypay-resource-id

# AppyPay Charges API
APPYPAY_BASE_URL=https://gwy-api.appypay.co.ao
APPYPAY_PAYMENT_METHOD_GPO=your-gpo-payment-method-id
APPYPAY_PAYMENT_METHOD_REFERENCE=your-reference-payment-method-id
APPYPAY_WEBHOOK_TOKEN=change-me-to-webhook-secret

# Domains
FRONTEND_URL=https://app.strongx.it.ao
API_URL=https://api.strongx.it.ao

# Pricing (AOA)
SMS_COST_PER_UNIT=5.00
EMAIL_COST_PER_UNIT=1.00
WHATSAPP_COST_PER_UNIT=8.00

# Admin seed user
ADMIN_PASSWORD=change-me-strong-password

# Frontend
NEXT_PUBLIC_API_URL=https://api.strongx.it.ao
NEXT_PUBLIC_WS_URL=https://api.strongx.it.ao
NEXT_PUBLIC_APP_NAME=StrongX
